RESEND_API_KEY=re_123456789
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# URL para los magic links en emails (servidor). En prod: https://triplenelson.com
BIZUM_SITE_URL=https://triplenelson.com
BIZUM_EMAIL_FROM=Triple Nelson <tickets@triplenelson.com>

# Bizum P2P config
BIZUM_EVENT_ID=triple-nelson-2026
BIZUM_EVENT_NAME=TRIPLE NELSON PRIVATE EVENT
BIZUM_FIXED_PRICE_EUR=20
BIZUM_FIELES_PRICE_EUR=50
BIZUM_INTENT_TTL_MINUTES=30

# Receivers
BIZUM_RECEIVER_1=689375753
BIZUM_RECEIVER_2=645342250
BIZUM_RECEIVER_3=616900446
BIZUM_RECEIVER_4=
# Emails de los receptores (para recibir notificación + magic link al confirmar pago)
BIZUM_RECEIVER_1_EMAIL=receptor1@ejemplo.com
BIZUM_RECEIVER_2_EMAIL=receptor2@ejemplo.com
BIZUM_RECEIVER_3_EMAIL=receptor3@ejemplo.com
BIZUM_RECEIVER_4_EMAIL=
# Nombres identificativos de los receptores (se muestran en el panel admin)
BIZUM_RECEIVER_1_LABEL=Habin
BIZUM_RECEIVER_2_LABEL=Jenas
BIZUM_RECEIVER_3_LABEL=Truja
BIZUM_RECEIVER_4_LABEL=
# Optional CSV override: BIZUM_RECEIVERS=689375753,645342250,616900446
BIZUM_CONTACT_EMAIL=organizacion@triplenelson.es

# Admin/Cron security
BIZUM_ADMIN_TOKEN=change-this-admin-token
BIZUM_ADMIN_USER=admin
BIZUM_ADMIN_PASSWORD=change-this-password
BIZUM_CRON_TOKEN=change-this-cron-token
BIZUM_VALIDATOR_TOKEN=change-this-validator-token

# ─── Fotos (S3) ──────────────────────────────────────────────────────────────
# Subida de fotos del evento a AWS S3. Ver docs/PHOTOS.md.
# Feature APAGADA por defecto y limitada a admins aunque se encienda.
FEATURE_PHOTOS_BUTTON_VISIBLE=true    # muestra el botón en la landing
FEATURE_PHOTO_UPLOAD_ENABLED=false    # galería cerrada, nadie puede subir ni ver fotos
PHOTO_UPLOAD_ADMINS_ONLY=true         # cuando se abra, solo admins primero
PHOTO_EVENT_ID=triple-nelson-2026    # prefijo de la key: photos/{eventId}/{uuid}.ext
PHOTO_MAX_FILE_SIZE_BYTES=10485760   # 10 MB (opcional)

# Credenciales AWS — SOLO servidor, nunca exponer al frontend
AWS_REGION=eu-west-1
AWS_S3_BUCKET_NAME=triplenelson-photos
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key
