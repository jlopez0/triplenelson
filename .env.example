BIZUM_EVENT_NAME=TRIPLE NELSON PRIVATE EVENT
BIZUM_FIXED_PRICE_EUR=16
BIZUM_FIELES_PRICE_EUR=50
BIZUM_INTENT_TTL_MINUTES=30

# Receivers
BIZUM_RECEIVER_1=689375753
BIZUM_RECEIVER_2=645342250
BIZUM_RECEIVER_3=616900446
BIZUM_RECEIVER_4=
# Emails de los receptores (para recibir notificación + magic link al confirmar pago)
BIZUM_RECEIVER_1_EMAIL=receptor1@ejemplo.com
BIZUM_RECEIVER_2_EMAIL=receptor2@ejemplo.com
BIZUM_RECEIVER_3_EMAIL=receptor3@ejemplo.com
BIZUM_RECEIVER_4_EMAIL=
